---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Badge from '../components/Badge.astro';
import '../styles/index.css';
import '../styles/dreams.css';

import siteData from '../data/site.json';
import projectsData from '../data/projects.json';
import gamesData from '../data/games.json';

const posts = await getCollection('blog');

// Compute hero stats (mirrors original load-index.js logic)
const projectCount = projectsData.length;
const blogCount = posts.length;
const gamesPlayed = (gamesData as any).games.filter((g: any) => g.status !== 'backlog').length;
const counts: Record<string, number> = { projects: projectCount, blog: blogCount, games: gamesPlayed };

const resolvedStats = siteData.hero.stats.map((s: any) => ({
  label: s.label,
  value: s.source ? (counts[s.source] ?? 0) : s.value,
}));
---

<Base title="MING-HAN LEE — Portfolio">
  <!-- Three.js neural network background (replaces CSS grid) -->
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <!-- Hero -->
  <section class="hero container">
    <div class="hero__inner">

      <div class="hero__left">
        <div class="hero__eyebrow">{siteData.hero.eyebrow}</div>

        <div class="glitch-wrap fade-up">
          <h1 class="glitch" data-text="MING-HAN">MING-HAN</h1><br>
          <h1 class="glitch" data-text="LEE">LEE</h1>
        </div>

        <p class="hero__name-sub fade-up">Robotics & AI Engineer</p>

        <div class="typewriter-wrap fade-up">
          <span class="typewriter-prompt">&gt;&nbsp;</span>
          <span id="typewriter"></span>
          <span class="cursor"></span>
        </div>

        <div class="hero__cta fade-up">
          <a href="/projects" class="btn">[ VIEW PROJECTS ]</a>
          <a href="/blog" class="btn btn--cyan">[ READ BLOG ]</a>
        </div>

        <div class="hero__stats fade-up" id="hero-stats">
          {resolvedStats.map(s => (
            <div class="stat">
              <span class="stat__value" data-count={s.value}>0</span>
              <span class="stat__label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="hero__photo-wrap fade-up">
        <div class="hero__photo-frame">
          <img
            src="/assets/photo.jpg"
            alt="Ming-Han Lee"
            class="hero__photo-img"
            onerror="this.style.display='none'; this.parentElement.querySelector('.hero__photo-placeholder').style.display='flex';"
          />
          <div class="hero__photo-placeholder">
            <span class="placeholder-icon">◈</span>
            <span class="placeholder-text">PHOTO.jpg</span>
            <span class="placeholder-sub">Replace assets/photo.jpg</span>
          </div>
          <div class="photo-scan" aria-hidden="true"></div>
          <div class="photo-corner photo-corner--tl" aria-hidden="true"></div>
          <div class="photo-corner photo-corner--tr" aria-hidden="true"></div>
          <div class="photo-corner photo-corner--bl" aria-hidden="true"></div>
          <div class="photo-corner photo-corner--br" aria-hidden="true"></div>
          <div class="photo-label" aria-hidden="true">ID::MHL_2026</div>
        </div>
      </div>

    </div>

    <div class="scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-hint__chevron"></div>
    </div>
  </section>

  <!-- About -->
  <section class="about container">
    <div class="about__grid">
      <div class="about__text fade-up">
        <span class="section-label">// ABOUT.exe</span>
        <h2 class="section-title">Bridging Algorithms and Action: Engineering the <em>Future</em> of AI in Robotics</h2>
        <div class="section-line" style="margin-bottom:2rem"></div>

        <div id="about-bio">
          {siteData.about.bio.map(p => <p set:html={p} />)}
        </div>

        <div class="about__skills" id="about-skills">
          {siteData.about.skills.map(s => <Badge label={s.label} color={s.color as any} />)}
        </div>
      </div>

      <div class="about__visual fade-up">
        <div class="about__card corner-box">
          <div class="about__card-label">SYSTEM INFO</div>
          <div id="about-system-info">
            {siteData.about.systemInfo.map((row: any) => (
              <div class="about__stat-row">
                <span class="about__stat-key">{row.key}</span>
                <span class="about__stat-val">
                  {row.href
                    ? <a href={row.href} target="_blank" style="color:var(--cyan)">{row.value}</a>
                    : row.color
                      ? <span style={`color:var(--${row.color})`}>{row.value}</span>
                      : row.value
                  }
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dream teaser -->
  <section class="container fade-up">
    <a href="/dreams" class="dream-teaser" style="text-decoration:none; color:inherit;">
      <div class="dream-teaser__left">
        <span class="dream-teaser__icon">🌕</span>
        <div>
          <div class="dream-teaser__label">// DREAMS.manifest</div>
          <div class="dream-teaser__title">Walk on the Moon &nbsp;·&nbsp; Physical AI &nbsp;·&nbsp; AI Infra at Scale</div>
        </div>
      </div>
      <span class="btn btn--cyan" style="pointer-events:none; flex-shrink:0;">[ VIEW DREAMS ]</span>
    </a>
  </section>

  <script is:inline>
    // Typewriter — runs after glitch.js is loaded by Base.astro
    (function() {
      var phrases = ["Frontier Physical AI","Learning-Based Robotics Control","Distributed System","ML Infrastructure","System Optimization"];
      var el = document.getElementById('typewriter');
      if (!el) return;
      var pIdx = 0, cIdx = 0, deleting = false;
      var SPEED_TYPE = 80, SPEED_DEL = 45, PAUSE = 1800;
      function tick() {
        var phrase = phrases[pIdx];
        if (!deleting) {
          el.textContent = phrase.slice(0, cIdx + 1);
          cIdx++;
          if (cIdx === phrase.length) { deleting = true; setTimeout(tick, PAUSE); return; }
          setTimeout(tick, SPEED_TYPE);
        } else {
          el.textContent = phrase.slice(0, cIdx - 1);
          cIdx--;
          if (cIdx === 0) { deleting = false; pIdx = (pIdx + 1) % phrases.length; setTimeout(tick, 300); return; }
          setTimeout(tick, SPEED_DEL);
        }
      }
      setTimeout(tick, 800);
      if (window.GlitchUtils) window.GlitchUtils.setupCounters();
    })();
  </script>

  <!-- Three.js neural network particle scene — Astro bundles this -->
  <script>
    import * as THREE from 'three';

    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (!canvas) throw new Error('hero-canvas not found');

    // Graceful degradation: skip if no WebGL
    if (!window.WebGLRenderingContext) {
      canvas.style.display = 'none';
      (document.querySelector('.hero-grid-fallback') as HTMLElement | null)?.style.setProperty('display', 'block');
    } else {
      initScene(canvas);
    }

    function initScene(canvas: HTMLCanvasElement) {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Renderer ────────────────────────────────────────────────────────
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
      renderer.setSize(window.innerWidth, window.innerHeight);

      // ── Scene & Camera ──────────────────────────────────────────────────
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 500);
      camera.position.z = 120;

      // ── Particle System ─────────────────────────────────────────────────
      const PARTICLE_COUNT = 220;
      const BOX = { x: 130, y: 80, z: 70 };

      // Positions and velocities
      const positions = new Float32Array(PARTICLE_COUNT * 3);
      const colors    = new Float32Array(PARTICLE_COUNT * 3);
      const velocities: number[][] = [];

      const palette = [
        new THREE.Color('#00F5FF'), // cyan  — 60%
        new THREE.Color('#FCEE09'), // yellow — 30%
        new THREE.Color('#FF006E'), // magenta — 10%
      ];

      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const i3 = i * 3;
        positions[i3]     = (Math.random() - 0.5) * BOX.x * 2;
        positions[i3 + 1] = (Math.random() - 0.5) * BOX.y * 2;
        positions[i3 + 2] = (Math.random() - 0.5) * BOX.z * 2;

        const spd = 0.04 + Math.random() * 0.06;
        velocities.push([
          (Math.random() - 0.5) * spd,
          (Math.random() - 0.5) * spd,
          (Math.random() - 0.5) * spd * 0.3,
        ]);

        const r = Math.random();
        const col = r < 0.6 ? palette[0] : r < 0.9 ? palette[1] : palette[2];
        colors[i3]     = col.r;
        colors[i3 + 1] = col.g;
        colors[i3 + 2] = col.b;
      }

      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

      const mat = new THREE.PointsMaterial({
        size: 1.4,
        vertexColors: true,
        transparent: true,
        opacity: 0.75,
        sizeAttenuation: true,
      });

      const points = new THREE.Points(geo, mat);
      scene.add(points);

      // ── Connection Lines ─────────────────────────────────────────────────
      const LINE_DIST = 34;
      const MAX_LINES = 450;

      const linePositions = new Float32Array(MAX_LINES * 2 * 3);
      const lineColors    = new Float32Array(MAX_LINES * 2 * 3);
      const lineGeo = new THREE.BufferGeometry();
      lineGeo.setAttribute('position', new THREE.BufferAttribute(linePositions, 3));
      lineGeo.setAttribute('color',    new THREE.BufferAttribute(lineColors, 3));

      const lineMat = new THREE.LineBasicMaterial({
        vertexColors: true,
        transparent: true,
        opacity: 0.18,
      });
      const lines = new THREE.LineSegments(lineGeo, lineMat);
      scene.add(lines);

      function updateLines() {
        let lIdx = 0;
        const pos = geo.attributes.position.array as Float32Array;
        const col = geo.attributes.color.array as Float32Array;

        for (let a = 0; a < PARTICLE_COUNT && lIdx < MAX_LINES; a++) {
          for (let b = a + 1; b < PARTICLE_COUNT && lIdx < MAX_LINES; b++) {
            const ax = pos[a * 3], ay = pos[a * 3 + 1], az = pos[a * 3 + 2];
            const bx = pos[b * 3], by = pos[b * 3 + 1], bz = pos[b * 3 + 2];
            const dist = Math.sqrt((ax-bx)**2 + (ay-by)**2 + (az-bz)**2);

            if (dist < LINE_DIST) {
              const li = lIdx * 6;
              linePositions[li]     = ax; linePositions[li + 1] = ay; linePositions[li + 2] = az;
              linePositions[li + 3] = bx; linePositions[li + 4] = by; linePositions[li + 5] = bz;
              // Blend colors of the two particles
              lineColors[li]     = (col[a*3]     + col[b*3])     / 2;
              lineColors[li + 1] = (col[a*3 + 1] + col[b*3 + 1]) / 2;
              lineColors[li + 2] = (col[a*3 + 2] + col[b*3 + 2]) / 2;
              lineColors[li + 3] = lineColors[li];
              lineColors[li + 4] = lineColors[li + 1];
              lineColors[li + 5] = lineColors[li + 2];
              lIdx++;
            }
          }
        }

        lineGeo.setDrawRange(0, lIdx * 2);
        lineGeo.attributes.position.needsUpdate = true;
        lineGeo.attributes.color.needsUpdate = true;
      }

      // ── Mouse parallax ───────────────────────────────────────────────────
      let targetRotX = 0, targetRotY = 0;
      let currentRotX = 0, currentRotY = 0;

      window.addEventListener('mousemove', (e) => {
        targetRotY = ((e.clientX / window.innerWidth)  - 0.5) * 0.15;
        targetRotX = ((e.clientY / window.innerHeight) - 0.5) * -0.10;
      });

      // ── Resize ───────────────────────────────────────────────────────────
      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });

      // ── Animation loop ───────────────────────────────────────────────────
      let hidden = false;
      document.addEventListener('visibilitychange', () => { hidden = document.hidden; });

      let frame = 0;
      function animate() {
        requestAnimationFrame(animate);
        if (hidden) return;

        frame++;
        const t = frame * 0.01;

        if (!prefersReduced) {
          // Move particles
          const pos = geo.attributes.position.array as Float32Array;
          for (let i = 0; i < PARTICLE_COUNT; i++) {
            const i3 = i * 3;
            pos[i3]     += velocities[i][0];
            pos[i3 + 1] += velocities[i][1];
            pos[i3 + 2] += velocities[i][2];

            // Wrap around box edges
            if (pos[i3]     >  BOX.x) pos[i3]     = -BOX.x;
            if (pos[i3]     < -BOX.x) pos[i3]     =  BOX.x;
            if (pos[i3 + 1] >  BOX.y) pos[i3 + 1] = -BOX.y;
            if (pos[i3 + 1] < -BOX.y) pos[i3 + 1] =  BOX.y;
            if (pos[i3 + 2] >  BOX.z) pos[i3 + 2] = -BOX.z;
            if (pos[i3 + 2] < -BOX.z) pos[i3 + 2] =  BOX.z;
          }
          geo.attributes.position.needsUpdate = true;

          // Update connections every 2 frames (perf)
          if (frame % 2 === 0) updateLines();

          // Pulse opacity on a slow sine
          mat.opacity = 0.65 + Math.sin(t * 0.8) * 0.12;
          lineMat.opacity = 0.14 + Math.sin(t * 0.6) * 0.06;

          // Mouse parallax — lerp toward target
          currentRotX += (targetRotX - currentRotX) * 0.04;
          currentRotY += (targetRotY - currentRotY) * 0.04;
          scene.rotation.x = currentRotX;
          scene.rotation.y = currentRotY;
        }

        renderer.render(scene, camera);
      }

      animate();
    }
  </script>
</Base>
