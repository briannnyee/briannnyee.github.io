---
import Base from '../layouts/Base.astro';
import '../styles/games.css';
---

<Base title="Games — Ming-Han Lee">
  <main class="games-page container">

    <!-- Save screen header -->
    <div class="save-header fade-up">
      <div class="save-header__top">
        <div>
          <div class="save-label">// SAVE_DATA.db — MING-HAN LEE</div>
          <h1 class="save-title">GAME <span>LOG</span></h1>
        </div>
        <div class="save-stats">
          <div class="save-stat">
            <span class="save-stat__val" id="completed-count">0</span>
            <span class="save-stat__key">Completed</span>
          </div>
          <div class="save-stat">
            <span class="save-stat__val" id="total-count">0</span>
            <span class="save-stat__key">Total</span>
          </div>
        </div>
      </div>
      <div class="save-progress">
        <div class="save-progress__bar">
          <div class="save-progress__fill" id="progress-fill"></div>
        </div>
        <span class="save-progress__label" id="progress-label">LOADING...</span>
      </div>
    </div>

    <!-- Ming-Han's List -->
    <section class="picks-section fade-up">
      <div class="picks-header">
        <span class="section-label">// MING-HAN'S_LIST</span>
        <span class="picks-sub">personal top picks from the collection</span>
      </div>
      <div class="picks-list" id="picks-list"></div>
    </section>

    <!-- Controls -->
    <div class="games-controls fade-up">
      <div class="search-wrap">
        <span class="search-icon">⌕</span>
        <input type="text" id="game-search" placeholder="Search games..." autocomplete="off" spellcheck="false" />
      </div>
      <div class="filter-row">
        <span class="filter-row__label">Status:</span>
        <button class="games-filter-btn active" data-status="all">All</button>
        <button class="games-filter-btn" data-status="completed">Completed</button>
        <button class="games-filter-btn" data-status="playing">Playing</button>
        <button class="games-filter-btn" data-status="backlog">Backlog</button>
      </div>
      <div class="filter-row">
        <span class="filter-row__label">Genre:</span>
        <button class="games-filter-btn active" data-genre="all">All</button>
        <button class="games-filter-btn" data-genre="RPG">RPG</button>
        <button class="games-filter-btn" data-genre="Action RPG">Action RPG</button>
        <button class="games-filter-btn" data-genre="Action">Action</button>
        <button class="games-filter-btn" data-genre="Roguelike">Roguelike</button>
      </div>
    </div>

    <!-- Featured Achievements ticker -->
    <div class="achievements-section fade-up">
      <div class="achievements-header">
        <span class="section-label">// FEATURED_ACHIEVEMENTS</span>
        <span class="ach-live-dot" aria-hidden="true"></span>
      </div>
      <div class="achievements-viewport">
        <div class="achievements-track" id="achievements-track"></div>
      </div>
    </div>

    <!-- Games grid (populated by games.js) -->
    <div class="games-grid" id="games-grid">
      <div class="no-results" id="no-results">
        <p>// NO_RESULTS_FOUND — try a different search</p>
      </div>
    </div>

    <p style="margin-top:2rem; font-family:var(--font-mono); font-size:0.7rem; color:var(--muted); text-align:center; letter-spacing:0.1em;">
      [ CLICK ANY CARD TO OPEN THE REVIEW ]
    </p>

  </main>

  <script is:inline src="/js/games.js"></script>
</Base>
